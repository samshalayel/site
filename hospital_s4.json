        "description": "تنفيذ API المختبر",
        "points": [
          "POST /lab-orders: requireRole('doctor') → validate → create order + items",
          "GET /lab-orders?status=: filter by status for technician queue",
          "PUT /lab-orders/:id/result: requireRole('technician') → update items with results",
          "GET /patients/:id/lab-results: aggregate results for doctor view",
          "Status machine: ordered → sample_collected → processing → resulted",
          "~300 سطر"
        ]
      },
      "position": { "x": 460, "y": 60 },
      "width": 360,
      "height": 300,
