      "data": {
        "label": "Frontend: Lab UI",
        "description": "تنفيذ واجهة المختبر",
        "points": [
          "LabOrderForm (doctor): select patient → choose tests → submit",
          "LabQueue (technician): pending orders table → click to enter results",
          "ResultEntryForm: per-test input fields → submit all → mark resulted",
          "PatientLabHistory (doctor): timeline of all lab results",
          "Status badges: color-coded by status (pending=yellow, resulted=green)",
          "~700 سطر"
