      "data": {
        "label": "Code Structure: Appointments",
        "description": "هيكل الكود لشريحة المواعيد",
        "points": [
          "prisma/schema.prisma → Doctor, Slot, Appointment models",
          "app/api/doctors/route.ts → GET doctors list",
          "app/api/doctors/[id]/slots/route.ts → GET available slots",
          "app/api/appointments/route.ts → GET + POST",
          "app/appointments/page.tsx → Calendar view + booking",
          "lib/validators/appointment.ts → booking validation + double-booking check"
        ]
      },
      "position": { "x": 40, "y": 60 },
      "width": 360,
      "height": 280,
      "parentId": "group-s4-slice2",
      "extent": "parent"
