    {
      "id": "s4-structure-reg",
      "type": "s4-code-structure-node",
      "data": {
        "label": "Code Structure: Registration",
        "description": "هيكل الكود لشريحة التسجيل",
        "points": [
          "prisma/schema.prisma → Patient model",
          "app/api/patients/route.ts → GET (list/search) + POST (create)",
          "app/api/patients/[id]/route.ts → GET + PUT",
          "app/patients/page.tsx → Patient list + search UI",
          "app/patients/new/page.tsx → Registration form",
          "lib/validators/patient.ts → Zod validation schemas"
        ]
      },
      "position": { "x": 40, "y": 60 },
      "width": 360,
      "height": 280,
      "parentId": "group-s4-slice1",
      "extent": "parent"
    },
    {
      "id": "s4-backend-reg",
      "type": "s4-backend-node",
      "data": {
        "label": "Backend: Patient APIs",
        "description": "تنفيذ API الخلفية",
        "points": [
          "POST /patients: validate → check nationalId unique → prisma.create → return patient",
          "GET /patients?q=: prisma.findMany({ where: { OR: [name contains, nationalId contains] } })",
          "GET /patients/:id: prisma.findUnique with relations",
          "PUT /patients/:id: validate → prisma.update",
          "Middleware: requireRole('receptionist', 'admin')",
          "~200 سطر"
        ]
      },
      "position": { "x": 460, "y": 60 },
      "width": 360,
      "height": 300,
      "parentId": "group-s4-slice1",
      "extent": "parent"
    },
    {
      "id": "s4-frontend-reg",
      "type": "s4-frontend-node",
      "data": {
        "label": "Frontend: Registration UI",
        "description": "تنفيذ واجهة التسجيل",
        "points": [
          "PatientForm: React Hook Form + Zod validation",
          "PatientSearch: debounced search input → live results",
          "PatientList: data table with sort + filter",
          "PatientDetail: view/edit patient info",
          "Shared: toast notifications + loading states",
          "~500 سطر"
        ]
      },
      "position": { "x": 880, "y": 60 },
      "width": 360,
      "height": 280,
      "parentId": "group-s4-slice1",
      "extent": "parent"
    },
    {
      "id": "s4-validation-reg",
      "type": "s4-validation-node",
      "data": {
        "label": "Validation: Registration",
        "description": "التحقق من جودة الكود",
        "points": [
          "Traceability: POST /patients ← S3 Contract ← S1 'تسجيل مريض جديد'",
          "nationalId unique enforcement ← S3 Constraint",
          "Zod schema matches Prisma model exactly",
          "No dead code — كل endpoint مستخدم من UI",
          "TypeScript strict: no any, no type assertions"
        ]
      },
      "position": { "x": 1200, "y": 60 },
      "width": 340,
      "height": 260,
      "parentId": "group-s4-slice1",
      "extent": "parent"
