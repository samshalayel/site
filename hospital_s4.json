    {
      "id": "s4-backend-appt",
      "type": "s4-backend-node",
      "data": {
        "label": "Backend: Appointment APIs",
        "description": "تنفيذ API المواعيد",
        "points": [
          "POST /appointments: validate → check slot available → prisma.create in transaction",
          "Double-booking prevention: SELECT FOR UPDATE on (doctorId, slotId, date)",
          "GET /doctors/:id/slots: compute available from schedule minus booked",
          "DELETE /appointments/:id: prisma.update({ status: 'cancelled' })",
          "Middleware: requireRole('receptionist', 'doctor', 'admin')",
          "~350 سطر"
        ]
      },
      "position": { "x": 460, "y": 60 },
      "width": 360,
      "height": 300,
      "parentId": "group-s4-slice2",
      "extent": "parent"
    },
    {
      "id": "s4-frontend-appt",
      "type": "s4-frontend-node",
      "data": {
        "label": "Frontend: Appointments UI",
        "description": "تنفيذ واجهة المواعيد",
        "points": [
          "DoctorSelector: cards/tabs لكل طبيب مع تخصصه",
          "CalendarView: week/day view مع slots ملونة (available/booked/cancelled)",
          "BookingModal: search patient → select slot → confirm",
          "AppointmentDetail: view details + cancel action",
          "Real-time slot refresh: SWR revalidation بعد كل حجز",
          "~800 سطر"
        ]
      },
      "position": { "x": 880, "y": 60 },
      "width": 360,
      "height": 280,
      "parentId": "group-s4-slice2",
      "extent": "parent"
    },
    {
      "id": "s4-integration-appt",
      "type": "s4-integration-node",
      "data": {
        "label": "Integration: Appointments ↔ Registration",
        "description": "تكامل المواعيد مع التسجيل",
        "points": [
          "BookingModal: يستخدم /patients?q= للبحث عن المريض",
          "Appointment.patientId → FK to Patient.id",
          "Patient detail page: يعرض قائمة مواعيد المريض",
          "Shared types: PatientSummary used in appointment context",
          "No circular dependency: appointments imports from patients, not vice versa"
        ]
      },
      "position": { "x": 1200, "y": 60 },
      "width": 340,
      "height": 260,
      "parentId": "group-s4-slice2",
