    {
      "id": "s2-components-3",
      "type": "s2-components-node",
      "data": {
        "label": "System Components",
        "description": "المكونات المعمارية الرئيسية",
        "points": [
          "DoctorSelector (UI): عرض tabs الأطباء — يرندر 3 tabs",
          "SlotGrid (UI): شبكة المواعيد لكل طبيب — 12 خانة",
          "BookingForm (UI): نموذج الحجز — اسم المريض + تأكيد",
          "BookingEngine (Logic): check-then-write atomically",
          "StorageAdapter (Data): JSON.parse/stringify → localStorage",
          "ToastNotifier (UI): رسائل تأكيد/خطأ"
        ]
      },
      "position": { "x": 880, "y": 80 },
      "width": 360,
      "height": 300,
      "parentId": "group-s2-20260513-pro001",
      "extent": "parent"
    },
    {
      "id": "s2-interactions-4",
      "type": "s2-interactions-node",
      "data": {
        "label": "Component Interactions",
        "description": "كيف المكونات تتواصل مع بعض",
        "points": [
          "DoctorSelector → SlotGrid: يرسل doctorIndex المختار",
          "SlotGrid → BookingForm: يرسل slotIndex + doctorIndex",
          "BookingForm → BookingEngine: يرسل { doctor, slot, patientName }",
          "BookingEngine → StorageAdapter: check(key) → write(key, name)",
          "BookingEngine → ToastNotifier: يرسل نتيجة (success/error)",
          "StorageAdapter → SlotGrid: يحدّث حالة الخانات",
          "CancelAction → BookingEngine → StorageAdapter: delete(key)"
        ]
      },
