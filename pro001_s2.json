        "description": "نموذج البيانات والتخزين",
        "points": [
          "Storage: localStorage — key: 'clinic_bookings'",
          "Format: JSON string → Record<string, string>",
          "Key Pattern: {doctorIndex}_{slotIndex} (e.g. '0_3')",
          "Value: اسم المريض (e.g. 'محمد أحمد')",
          "Operations: READ → CHECK → ADD/REMOVE → WRITE",
          "Constraint: key فريد — لا يمكن الكتابة فوق قيمة موجودة"
        ]
      },
