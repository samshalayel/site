      "data": {
        "label": "Domain Model",
        "description": "المفاهيم الأساسية في النطاق",
        "points": [
          "Doctor: { index, name, color } — طبيب العيادة",
          "Slot: { doctorIndex, slotIndex, time } — خانة موعد",
          "Booking: { key: doctorIndex_slotIndex, value: patientName } — حجز",
          "Schedule: Doctor → Slot[] → Booking? — جدول الطبيب اليومي"
        ]
      },
